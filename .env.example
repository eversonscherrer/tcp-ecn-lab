# accecn1 = server
SERVER_HOST=192.168.0.10
SERVER_USER=accecn
SERVER_PORT=22

# accecn2 = client
CLIENT_HOST=192.168.0.11
CLIENT_USER=accecn
CLIENT_PORT=22

# Usually the same as SSH host above. Change only if the VMs communicate
# over a different network interface than the SSH management network.
SERVER_IP=192.168.0.10
CLIENT_IP=192.168.0.11

# Optional. Auto-detected from "ip route get CLIENT_IP" on the server when empty.
# SERVER_IFACE=ens18

REMOTE_DIR=/home/accecn/accecn-tcp-experiment
